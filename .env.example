APP_NAME="SmartBudget API"
APP_ENV=dev
APP_VERSION=0.1.0
APP_HOST=127.0.0.1
APP_PORT=8400
BACKEND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Database (example only — do NOT use real credentials here)
DATABASE_URL=postgresql+psycopg://user:password@localhost:5433/db_name
# Security
SECRET_KEY=your-secret-key-here
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name
UPLOAD_DIR=uploads

MAIL_FROM_EMAIL=your_email@example.com
MAIL_FROM_NAME=SmartBudget
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=your_email@gmail.com
MAIL_SMTP_PASSWORD=your_app_password
MAIL_SMTP_TLS=true

ADMIN_TOKEN=secret

CALENDLY_CONSULTATION_URL=
CALENDLY_WEBHOOK_SIGNING_SECRET=
CALENDLY_PERSONAL_ACCESS_TOKEN=

R2_ACCOUNT_ID=<your Cloudflare Account ID>
R2_ACCESS_KEY_ID=<your Access Key ID>
R2_SECRET_ACCESS_KEY=<your Secret Access Key>
R2_BUCKET_NAME=smartbudget-product-releases
R2_PRODUCT_RELEASES_PREFIX=product-releases